# ============================================================================
# Financial Analysis API - .gitignore
# Security & Governance: Protects sensitive financial data and credentials
# Updated: March 2, 2026
# ============================================================================

# ============================================================================
# SECURITY: NEVER COMMIT THESE FILES
# ============================================================================

# 🔐 Environment Files & Secrets
# Contains database passwords, API keys, SECRET_KEY, etc.
.env
.env.local
.env.*.local
.env.production
.env.staging
.env.test
*.env.local
app/backend/.env
app/backend/.env.local

# 🔐 Credentials & Secrets
secrets.yaml
secrets.yml
.credentials
.aws/credentials
.aws/config
*.pem
*.key
*.p8
*.p12
*.pfx
*.jks

# 🔐 Database Files with Data
# Never commit databases with real data
*.sqlite
*.sqlite3
*.db
app/backend/db.sqlite3
app/backend/db.sqlite3-journal
*.db-journal
app/backend/*.db

# ============================================================================
# FINANCIAL SECURITY: NEVER COMMIT FINANCIAL DOCUMENTS
# ============================================================================

# 📄 Bank Statements & Financial Documents
# These contain personal financial information and must NEVER be committed
finances/
# Exception: Allow test data and documentation (fabricated, safe data)
!finances/README.md
!finances/**/test-transactions-demo.csv

*.pdf
*.PDF
*bank*.pdf
*statement*.pdf
*account*.pdf
*transaction*.csv
*transactions*.csv
*export*.csv
# Exception: Allow test data CSVs (fabricated data)
!*test-transactions-demo.csv
*download*.csv
*.ofx
*.qbo
*.iif

# 🏦 Specific Financial Document Patterns
bank-5/
bank-1/
bank-2/
bank-4/
bank-3/
citibank/
*statement*
*reconciliation*
*bank-rec*
*account-statement*

# 📊 Data Exports & Backups
# Any exported or backed up financial data
*.xlsx
*.xls
*.xlsm
/exports/
/backups/
*.backup
*.bak
/data/imports/
/data/exports/

# ============================================================================
# LOGS & SENSITIVE RUNTIME DATA
# ============================================================================

# 📝 Logs
*.log
*.log.*
logs/
/logs/
django.log
app.log
error.log
debug.log
*.out

# 🔍 Sentry/Error Tracking
.sentry

# 📊 Metrics & Monitoring
/metrics/
prometheus/
grafana/

# ============================================================================
# PERSONAL & USER DATA
# ============================================================================

# 👤 User Data Files
/user_data/
/uploads/
/tmp/
/temp/
*.dat
*.data

# 📎 User-Generated Files (if any upload feature)
/uploads/
/media/files/
/media/documents/

# ============================================================================
# PYTHON
# ============================================================================

__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ============================================================================
